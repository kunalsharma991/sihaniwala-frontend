# Frontend Environment Variables (Vite)
# Copy to frontend/.env and update values for your environment.
# Note: these VITE_ variables are bundled into the public JS at build time -
# only put PUBLIC/publishable keys here, never secret keys.

# Backend API base URL
VITE_API_URL=http://localhost:8080

# Razorpay publishable Key ID (safe to expose client-side)
VITE_RAZORPAY_KEY_ID=rzp_test_your_key_id

# PayPal Client ID (safe to expose client-side)
VITE_PAYPAL_CLIENT_ID=your_paypal_client_id
